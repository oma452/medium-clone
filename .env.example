APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080   # ⬅️ changed to match Apache container port

SCRIBE_BASE_URL=http://127.0.0.1:8080  # optional, match above

DB_CONNECTION=mysql
DB_HOST=db              # ⬅️ service name of DB container
DB_PORT=3306
DB_DATABASE=medium_clone
DB_USERNAME=laravel     # ⬅️ match docker-compose.yml
DB_PASSWORD=secret      # ⬅️ match docker-compose.yml

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

REDIS_CLIENT=phpredis
REDIS_HOST=redis        # ⬅️ only if you add redis container later
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog       # ⬅️ if you add Mailhog container for dev email
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
